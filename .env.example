# ======================
# EDUAI DATA LAKE CONFIG
# ======================
EDUAI_DATA_PATH=/Users/mac/Library/CloudStorage/SynologyDrive-education
QDRANT_PORT=6333

# Use Docker
#EDUAI_DATA_BASE_PATH=/data
#QDRANT_HOST=qdrant
#API_BASE_URL=http://lakeflow-backend:8011


# Not using Docker (backend reads LAKEFLOW_DATA_BASE_PATH, not EDUAI_*)
LAKEFLOW_DATA_BASE_PATH=/Users/mac/Library/CloudStorage/SynologyDrive-education
EDUAI_DATA_BASE_PATH=/Users/mac/Library/CloudStorage/SynologyDrive-education
QDRANT_HOST=localhost
API_BASE_URL=http://localhost:8011

# Q&A / Admission agent: Ollama URL (or OpenAI-compatible). Server running LakeFlow MUST be able to reach this URL.
# If deploying on internal machine that cannot reach research.neu.edu.vn → set internal Ollama URL (e.g. http://ollama-host:11434 or http://10.2.13.xx:11434).
# "No route to host" when calling /ask = LLM_BASE_URL not reachable from LakeFlow server.
# Linux Docker: host.docker.internal cần extra_hosts (đã thêm trong docker-compose.yml)
LLM_BASE_URL=https://research.neu.edu.vn/ollama
# OLLAMA_EMBED_URL: mặc định = LLM_BASE_URL/api/embed. Set riêng nếu embed chạy khác (vd. host.docker.internal:8002)
# OLLAMA_EMBED_URL=
LLM_MODEL=qwen3:8b
# Set true if proxy returns 405 for /v1/chat/completions (use native /api/chat instead)
# USE_OLLAMA_NATIVE_CHAT=true

